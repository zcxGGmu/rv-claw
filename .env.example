# RV-Claw 环境变量配置示例
# ⚠️ DO NOT COMMIT REAL VALUES — 复制此文件为 .env 并填入真实值

# ── 通用 ──
ENVIRONMENT=local

# ── LLM 模型 ──
DS_MODEL=deepseek-chat
DS_API_KEY=***
DS_URL=https://api.deepseek.com/v1
MAX_TOKENS=2000
TEMPERATURE=0.7
CONTEXT_WINDOW=131072

# ── Claude Agent SDK ──
CLAUDE_API_KEY=***
CLAUDE_MODEL=claude-sonnet-4

# ── OpenAI Agents SDK ──
OPENAI_API_KEY=***
OPENAI_MODEL=gpt-4o
CODEX_MODEL=codex-mini

# ── 认证 ──
AUTH_PROVIDER=local
HTTPS_ONLY=false
SESSION_COOKIE=zdtc-agent-session
SESSION_MAX_AGE=604800

# ── Admin 引导 ──
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_FULLNAME=Administrator
BOOTSTRAP_ADMIN_EMAIL=admin@localhost
BOOTSTRAP_UPDATE_ADMIN_PASSWORD=true

# ── MongoDB ──
MONGODB_HOST=mongo
MONGODB_PORT=27017
MONGODB_DB=ai_agent
MONGODB_USER=scienceone
MONGODB_PASSWORD=Yp51Bi1eEjC77sAt

# ── PostgreSQL (LangGraph Checkpointer) ──
POSTGRES_URI=postgresql+asyncpg://rv:rv_password@postgres:5432/rv_checkpoints

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Pipeline 配置 ──
MAX_REVIEW_ITERATIONS=3
MAX_AGENT_TURNS=50
MAX_CONCURRENT_CLAUDE=3
MAX_CONCURRENT_OPENAI=5
MAX_CONCURRENT_QEMU=2

# ── 成本限制 ──
MAX_COST_PER_CASE=10.0
MAX_COST_PER_HOUR=50.0

# ── Feature Flags ──
PIPELINE_ENABLED=false
QEMU_SANDBOX_ENABLED=false

# ── 沙盒 ──
SANDBOX_MEM_LIMIT=8g
SANDBOX_CPUS=4
SANDBOX_REST_URL=http://sandbox:8080

# ── WebSearch ──
WEBSEARCH_BASE_URL=http://websearch:8068
WEBSEARCH_API_KEY=fdsfkjikmii

# ── 任务调度 ──
TASK_SERVICE_API_KEY=

# ── IM (飞书/微信) ──
IM_ENABLED=true
IM_RESPONSE_TIMEOUT=300
IM_MAX_MESSAGE_LENGTH=4000
LARK_ENABLED=true
LARK_APP_ID=
LARK_APP_SECRET=

# ── 日志 ──
LOG_LEVEL=INFO
DIAGNOSTIC_MODE=1

# ── 文件下载 ──
FILE_DOWNLOAD_ALLOWED_PREFIXES=/tmp,/app,/home/scienceclaw
